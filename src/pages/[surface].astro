---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicPages, type PublicPage } from "../content/public-pages";
import GlossaryText from "../components/GlossaryText.astro";
import PublicShareDock from "../components/PublicShareDock.astro";

export function getStaticPaths() {
  return publicPages.map((page) => ({
    params: {
      surface: page.id
    },
    props: {
      page
    }
  }));
}

interface Props {
  page: PublicPage;
}

const { page } = Astro.props as Props;
const isDesignPage = page.id === "design";
const heroHeading = page.heading;
const heroSummary = page.summary;
const title = `${heroHeading} - 8ailors`;
const description = heroSummary ?? `${heroHeading} - 8ailors`;
const designOverviewSection = {
  id: "design-start",
  label: "Overview",
  title: "적용 범위"
} as const;
const designContentSections = [
  {
    id: "design-consistency",
    label: "일관성",
    title: "어디서나 같은 경험",
    body: "버튼, 입력, 링크는 어느 화면에서든 같은 규칙을 씁니다. 한 화면에서 익힌 조작이 전체에 통하기 때문에, 새로운 화면에 들어가도 조작법을 다시 배울 필요가 없습니다."
  },
  {
    id: "design-accessibility",
    label: "접근성",
    title: "키보드와 스크린 리더",
    body: "마우스 없이 키보드로 모든 요소를 탐색할 수 있습니다. 포커스 위치는 항상 화면에 표시되고, 스크린 리더용 랜드마크도 빠뜨리지 않습니다. 시각, 운동, 인지적 차이에 관계없이 정보에 접근할 수 있습니다."
  },
  {
    id: "design-safety",
    label: "안전",
    title: "실수 방지",
    body: "삭제·결제처럼 되돌리기 어려운 작업은 슬라이드하거나 2초 이상 누른 뒤에만 실행됩니다. 의도를 명확히 확인한 뒤에 작동하며, 실수로 중요한 데이터를 잃지 않도록 합니다."
  },
  {
    id: "design-locale",
    label: "현지화",
    title: "내 언어로",
    body: "한국어·영어로 시작하며, 스페인어·중국어·힌디어·프랑스어·일본어·독일어·포르투갈어·인도네시아어까지 10개 언어로 확대합니다. 언어 설정에 따라 서체와 줄바꿈 방식이 자동으로 바뀌어, 각 언어의 가독성을 최적화합니다."
  }
] as const;
const hasOverviewSection = isDesignPage;
const hasDetailsSection = isDesignPage || page.details.length > 0;
const hasChecksSection = isDesignPage || page.checks.length > 0;
const hasPageDetailContent =
  hasOverviewSection ||
  hasDetailsSection ||
  hasChecksSection;
const detailSectionLabelId = hasOverviewSection
  ? "design-start-title"
  : hasDetailsSection
    ? "design-details-title"
    : "design-checks-title";
---

<BaseLayout title={title} description={description} currentPath={page.path}>
  <section class="page-hero zdp-section zdp-section--spacing-xl page-hero--docs" aria-labelledby="page-title">
    <div class="page-hero__inner zdp-container zdp-container--lg zdp-container--padding-md">
      <nav class="zdp-breadcrumb page-breadcrumb" aria-label="현재 위치">
        <ol class="zdp-breadcrumb__list">
          <li class="zdp-breadcrumb__item">
            <a class="zdp-breadcrumb__link" href="/">8ailors</a>
          </li>
          <li class="zdp-breadcrumb__item">
            <span class="zdp-breadcrumb__separator" aria-hidden="true">/</span>
            <span class="zdp-breadcrumb__current" aria-current="page">{page.label}</span>
          </li>
        </ol>
      </nav>
      <header class="zdp-page-header zdp-page-header--align-start" aria-labelledby="page-title">
        <div class="zdp-page-header__body">
          <div class="zdp-page-header__title">
            <h1 id="page-title">{heroHeading}</h1>
          </div>
          {heroSummary && (
            <div class="zdp-page-header__summary">
              <p><GlossaryText text={heroSummary} /></p>
            </div>
          )}
        </div>
        <div class="zdp-page-header__actions">
          <a class="zdp-button zdp-button--md zdp-button--secondary" href="/">
            홈으로 돌아가기
          </a>
        </div>
      </header>
    </div>
  </section>

  {hasPageDetailContent && (
    <section
      class="design-doc zdp-section zdp-section--spacing-lg zdp-divider zdp-divider--horizontal zdp-divider--subtle"
      aria-labelledby={detailSectionLabelId}
    >
    <div class="design-doc__layout zdp-container zdp-container--lg zdp-container--padding-md">
      <aside class="design-doc__rail" aria-label={`${page.label} 문서 네비게이션`}>
        <p class="section-label">목차</p>
        <nav class="design-doc__nav" aria-label={`${page.label} 섹션`}>
          {hasOverviewSection && <a class="zdp-link zdp-link--muted" href="#design-start">개요</a>}
          {isDesignPage && <a class="zdp-link zdp-link--muted" href="#design-showcase">미리보기</a>}
          {isDesignPage && designContentSections.map((section) => (
            <a class="zdp-link zdp-link--muted" href={`#${section.id}`}>{section.label}</a>
          ))}
          {hasDetailsSection && <a class="zdp-link zdp-link--muted" href="#design-details">{isDesignPage ? "상세" : "상세"}</a>}
          {hasChecksSection && <a class="zdp-link zdp-link--muted" href="#design-checks">{isDesignPage ? "약속" : "체크리스트"}</a>}
        </nav>
      </aside>

      <article class="design-doc__article">
        {hasOverviewSection && (
          <section id="design-start" class="design-doc__section" aria-labelledby="design-start-title">
            <h2 id="design-start-title">{designOverviewSection.title}</h2>
            <div class="design-doc__platforms zdp-inline zdp-inline--gap-xs" aria-label="적용 대상">
              <span class="zdp-badge zdp-badge--neutral zdp-badge--sm">Astro</span>
              <span class="zdp-badge zdp-badge--neutral zdp-badge--sm">Svelte</span>
              <span class="zdp-badge zdp-badge--neutral zdp-badge--sm">Tauri</span>
              <span class="zdp-badge zdp-badge--neutral zdp-badge--sm">Flutter tokens</span>
            </div>
          </section>
        )}

        {isDesignPage && (
          <section id="design-showcase" class="design-doc__section" aria-labelledby="design-showcase-title">
            <p class="section-label">미리보기</p>
            <h2 id="design-showcase-title">컴포넌트 & 토큰 카탈로그</h2>
            <p><GlossaryText text="공통 테마로 적용되는 원천 토큰과 UI 요소의 실물 사양입니다." /></p>

            <div class="showcase-group">
              <h3 class="showcase-group__title">Color Palette — Light</h3>
              <div class="swatch-grid">
                <div class="swatch-card" style="background: var(--zdp-color-surface-canvas); border: 1px solid var(--zdp-color-line-subtle);">
                  <div class="swatch-info">
                    <span class="swatch-name">Surface Canvas</span>
                    <code class="swatch-token">--zdp-color-surface-canvas</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-surface-panel); border: 1px solid var(--zdp-color-line-subtle);">
                  <div class="swatch-info">
                    <span class="swatch-name">Surface Panel</span>
                    <code class="swatch-token">--zdp-color-surface-panel</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-surface-raised); border: 1px solid var(--zdp-color-line-subtle);">
                  <div class="swatch-info">
                    <span class="swatch-name">Surface Raised</span>
                    <code class="swatch-token">--zdp-color-surface-raised</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-ink-normal); color: var(--zdp-color-ink-inverse);">
                  <div class="swatch-info">
                    <span class="swatch-name">Ink Normal</span>
                    <code class="swatch-token">--zdp-color-ink-normal</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-ink-muted); color: var(--zdp-color-ink-inverse);">
                  <div class="swatch-info">
                    <span class="swatch-name">Ink Muted</span>
                    <code class="swatch-token">--zdp-color-ink-muted</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-accent-primary); border: 1px solid var(--zdp-color-line-subtle);">
                  <div class="swatch-info">
                    <span class="swatch-name">Accent Primary</span>
                    <code class="swatch-token">--zdp-color-accent-primary</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-accent-success); color: var(--zdp-color-ink-inverse);">
                  <div class="swatch-info">
                    <span class="swatch-name">Accent Success</span>
                    <code class="swatch-token">--zdp-color-accent-success</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-accent-warning); color: var(--zdp-color-ink-inverse);">
                  <div class="swatch-info">
                    <span class="swatch-name">Accent Warning</span>
                    <code class="swatch-token">--zdp-color-accent-warning</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-accent-danger); color: var(--zdp-color-ink-inverse);">
                  <div class="swatch-info">
                    <span class="swatch-name">Accent Danger</span>
                    <code class="swatch-token">--zdp-color-accent-danger</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: var(--zdp-color-focus-surface); border: 1px solid var(--zdp-color-focus-line);">
                  <div class="swatch-info">
                    <span class="swatch-name">Focus Surface</span>
                    <code class="swatch-token">--zdp-color-focus-surface</code>
                  </div>
                </div>
              </div>
            </div>

            <div class="showcase-group">
              <h3 class="showcase-group__title">Color Palette — Dark</h3>
              <div class="swatch-grid" data-zdp-theme="dark" style="padding: var(--zdp-space-4); border-radius: var(--zdp-radius-md); background: oklch(23% 0.035 70);">
                <div class="swatch-card" style="background: oklch(23% 0.035 70); border: 1px solid oklch(43% 0.055 76);">
                  <div class="swatch-info">
                    <span class="swatch-name">Surface Canvas</span>
                    <code class="swatch-token">--zdp-color-surface-canvas</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: oklch(27% 0.04 70); border: 1px solid oklch(43% 0.055 76);">
                  <div class="swatch-info">
                    <span class="swatch-name">Surface Panel</span>
                    <code class="swatch-token">--zdp-color-surface-panel</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: oklch(34% 0.05 70); border: 1px solid oklch(43% 0.055 76);">
                  <div class="swatch-info">
                    <span class="swatch-name">Surface Raised</span>
                    <code class="swatch-token">--zdp-color-surface-raised</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: oklch(91% 0.045 82); border: 1px solid oklch(43% 0.055 76);">
                  <div class="swatch-info">
                    <span class="swatch-name">Ink Normal</span>
                    <code class="swatch-token">--zdp-color-ink-normal</code>
                  </div>
                </div>
                <div class="swatch-card" style="background: oklch(84% 0.1 86); border: 1px solid oklch(43% 0.055 76);">
                  <div class="swatch-info">
                    <span class="swatch-name">Focus Surface</span>
                    <code class="swatch-token">--zdp-color-focus-surface</code>
                  </div>
                </div>
              </div>
            </div>

            <div class="showcase-group">
              <h3 class="showcase-group__title">Typography</h3>
              <div class="typography-specimen zdp-surface zdp-surface--panel zdp-surface--padding-md">
                <div class="specimen-row">
                  <span class="specimen-label">Page Title</span>
                  <div class="specimen-content">
                    <h1 style="margin: 0; font-family: var(--font-title); font-size: var(--zdp-type-page-title-size); font-weight: var(--zdp-font-weight-medium);">Heading 1</h1>
                  </div>
                </div>
                <div class="specimen-row">
                  <span class="specimen-label">Section Title</span>
                  <div class="specimen-content">
                    <h2 style="margin: 0; font-family: var(--font-title); font-size: 2rem; font-weight: var(--zdp-font-weight-medium);">Heading 2</h2>
                  </div>
                </div>
                <div class="specimen-row">
                  <span class="specimen-label">Body Text</span>
                  <div class="specimen-content">
                    <p style="margin: 0; line-height: 1.6;">가독성을 높인 본문 기본 텍스트 폰트와 자간 배치입니다.</p>
                  </div>
                </div>
                <div class="specimen-row">
                  <span class="specimen-label">Brand Logo</span>
                  <div class="specimen-content">
                    <span style="margin: 0; font-family: var(--font-logo); font-size: 1.5rem; font-weight: var(--zdp-font-weight-semibold);">8ailors</span>
                  </div>
                </div>
                <div class="specimen-row">
                  <span class="specimen-label">Code Block</span>
                  <div class="specimen-content">
                    <code style="margin: 0;">import 'zdp-design-system';</code>
                  </div>
                </div>
              </div>
            </div>

            <div class="showcase-group">
              <h3 class="showcase-group__title">Interactive Components</h3>
              <div class="components-preview zdp-surface zdp-surface--panel zdp-surface--padding-lg">
                <div class="preview-item">
                  <span class="preview-label">Buttons</span>
                  <div class="preview-row zdp-inline zdp-inline--gap-sm">
                    <button class="zdp-button zdp-button--md zdp-button--primary">Primary Button</button>
                    <button class="zdp-button zdp-button--md zdp-button--secondary">Secondary Button</button>
                  </div>
                </div>

                <div class="preview-item">
                  <span class="preview-label">Badges</span>
                  <div class="preview-row zdp-inline zdp-inline--gap-xs">
                    <span class="zdp-badge zdp-badge--primary zdp-badge--sm">Primary</span>
                    <span class="zdp-badge zdp-badge--neutral zdp-badge--sm">Neutral</span>
                    <span class="zdp-badge zdp-badge--success zdp-badge--sm">Success</span>
                    <span class="zdp-badge zdp-badge--warning zdp-badge--sm">Warning</span>
                    <span class="zdp-badge zdp-badge--danger zdp-badge--sm">Danger</span>
                  </div>
                </div>

                <div class="preview-item">
                  <span class="preview-label">Shortcuts</span>
                  <div class="preview-row zdp-inline zdp-inline--gap-xs">
                    <kbd class="zdp-kbd zdp-kbd--md">/</kbd>
                    <span>키로 글로벌 검색 포커스</span>
                  </div>
                </div>

                <div class="preview-item">
                  <span class="preview-label">CommandField</span>
                  <div class="preview-row">
                    <div class="zdp-command-field-shell" style="max-width: 28rem;">
                      <input
                        class="zdp-command-field zdp-command-field__input"
                        type="search"
                        placeholder="프로젝트, 문서, 설정 검색"
                        aria-label="빠른 이동"
                        readonly
                      />
                      <span class="zdp-shortcut-hint" aria-hidden="true">
                        <kbd class="zdp-kbd zdp-kbd--md">/</kbd>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="preview-item">
                  <span class="preview-label">EmptyState</span>
                  <div class="preview-row">
                    <div class="zdp-empty-state zdp-empty-state--raised" style="max-width: 28rem;">
                      <div class="zdp-empty-state__body">
                        <p style="margin: 0; font-weight: var(--zdp-font-weight-medium);">아직 공개할 항목이 없습니다.</p>
                        <p style="margin: var(--zdp-space-1) 0 0; color: var(--zdp-color-ink-muted); font-size: var(--zdp-font-size-sm);">준비되면 여기에 표시됩니다.</p>
                      </div>
                      <div class="zdp-empty-state__actions">
                        <button class="zdp-button zdp-button--md zdp-button--secondary">새로 고침</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="showcase-group">
              <h3 class="showcase-group__title">Spacing & Motion Tokens</h3>
              <div class="zdp-surface zdp-surface--panel zdp-surface--padding-md" style="display: flex; flex-direction: column; gap: var(--zdp-space-4);">
                <div>
                  <p class="section-label" style="margin: 0 0 var(--zdp-space-2);">Spacing Scale</p>
                  <div class="preview-row zdp-inline zdp-inline--gap-xs" style="align-items: flex-end;">
                    {[1, 2, 3, 4, 5, 6, 8, 10, 12].map((step) => (
                      <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
                        <div style={`width: calc(var(--zdp-space-${step}) + 0.25rem); height: calc(var(--zdp-space-${step}) + 0.25rem); min-width: 4px; min-height: 4px; background: var(--zdp-color-accent-primary-strong); border-radius: var(--zdp-radius-sm);`}></div>
                        <code style="font-size: 0.7rem; color: var(--zdp-color-ink-muted);">{step}</code>
                      </div>
                    ))}
                  </div>
                </div>
                <div>
                  <p class="section-label" style="margin: 0 0 var(--zdp-space-2);">Motion</p>
                  <dl class="zdp-key-value zdp-key-value--columns-two" style="font-size: var(--zdp-font-size-xs);">
                    <dt>--zdp-motion-fast</dt><dd>120ms</dd>
                    <dt>--zdp-motion-normal</dt><dd>180ms</dd>
                    <dt>prefers-reduced-motion</dt><dd>1ms로 낮춤</dd>
                  </dl>
                </div>
                <div>
                  <p class="section-label" style="margin: 0 0 var(--zdp-space-2);">Border Radius</p>
                  <div class="preview-row zdp-inline zdp-inline--gap-sm">
                    {[
                      { name: "sm", value: "0.25rem" },
                      { name: "md", value: "0.375rem" },
                      { name: "lg", value: "0.5rem" },
                      { name: "pill", value: "999px" }
                    ].map((r) => (
                      <div style="display: flex; flex-direction: column; align-items: center; gap: var(--zdp-space-1);">
                        <div style={`width: 2.5rem; height: 2.5rem; background: var(--zdp-color-accent-primary); border-radius: var(--zdp-radius-${r.name});`}></div>
                        <code style="font-size: 0.7rem; color: var(--zdp-color-ink-muted);">{r.name}</code>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </section>
        )}

        {isDesignPage && designContentSections.map((section) => (
          <section id={section.id} class="design-doc__section" aria-labelledby={`${section.id}-title`}>
            <p class="section-label">{section.label}</p>
            <h2 id={`${section.id}-title`}>{section.title}</h2>
            <p><GlossaryText text={section.body} /></p>
          </section>
        ))}

        {hasDetailsSection && (
          <section id="design-details" class="design-doc__section" aria-labelledby="design-details-title">
            <p class="section-label">{isDesignPage ? "Details" : "상세"}</p>
            <h2 id="design-details-title">{isDesignPage ? "디자인 상세" : "핵심 정보"}</h2>
            <div class="details-grid zdp-grid zdp-grid--columns-two zdp-grid--gap-md">
              {page.details.map((detail) => (
                <article class="detail-card zdp-surface zdp-surface--panel zdp-surface--padding-md">
                  <h3>{detail.title}</h3>
                  <p><GlossaryText text={detail.body} /></p>
                </article>
              ))}
            </div>
          </section>
        )}

        {hasChecksSection && (
          <section id="design-checks" class="design-doc__section" aria-labelledby="design-checks-title">
            <p class="section-label">Checklist</p>
            <h2 id="design-checks-title">검증 체크리스트</h2>
            <div class="zdp-table-wrap">
              <table class="zdp-table zdp-table--density-compact" aria-labelledby="design-checks-title">
                <caption class="zdp-table__caption zdp-table__caption--hidden">{isDesignPage ? "디자인 검증 체크리스트" : "검증 체크리스트"}</caption>
                <thead>
                  <tr>
                    <th scope="col">항목</th>
                    <th scope="col">상태</th>
                    <th scope="col">기준</th>
                  </tr>
                </thead>
                <tbody>
                  {page.checks.map((check) => (
                    <tr>
                      <th scope="row">{check.item}</th>
                      <td>{check.status}</td>
                      <td><GlossaryText text={check.note} /></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}
      </article>

      <PublicShareDock pageId={page.id} title={heroHeading} text={heroSummary ?? heroHeading} path={page.path} placement="rail" />
    </div>
    </section>
  )}

  <script>
    type SharePayload = {
      title: string;
      text: string;
      url: string;
    };

    const sharePanels = document.querySelectorAll("[data-share-panel]");

    function buildShareHref(platform: string | null, payload: SharePayload): string {
      const encodedUrl = encodeURIComponent(payload.url);
      const encodedTitle = encodeURIComponent(payload.title);

      switch (platform) {
        case "telegram":
          return `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`;
        case "line":
          return `https://social-plugins.line.me/lineit/share?url=${encodedUrl}&text=${encodedTitle}`;
        case "whatsapp":
          return `https://wa.me/?text=${encodeURIComponent([payload.title, payload.url].filter(Boolean).join(" "))}`;
        case "x":
          return `https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
        case "reddit":
          return `https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`;
        default:
          return payload.url;
      }
    }

    async function copyShareText(text: string): Promise<boolean> {
      if (!navigator.clipboard?.writeText) {
        return false;
      }

      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        return false;
      }
    }

    for (const panel of sharePanels) {
      const pageUrl = new URL(window.location.href);
      pageUrl.hash = "";
      const payload = {
        title: panel.getAttribute("data-share-title") || document.title,
        text: panel.getAttribute("data-share-text") || "",
        url: pageUrl.toString()
      };
      const feedback = panel.querySelector("[data-share-feedback]");
      const copyButton = panel.querySelector('[data-share-action="copy"]');
      const deviceButton = panel.querySelector('[data-share-action="device"]');

      for (const link of panel.querySelectorAll("[data-share-platform]")) {
        const platform = link.getAttribute("data-share-platform");
        link.setAttribute("href", buildShareHref(platform, payload));
      }

      copyButton?.addEventListener("click", async () => {
        const copied = await copyShareText(payload.url);
        const copiedText = copyButton.getAttribute("data-share-copied-label") || "복사됨";
        if (feedback) {
          feedback.textContent = copied ? copiedText : "복사 권한 필요";
        }
        window.setTimeout(() => {
          if (feedback) {
            feedback.textContent = "";
          }
        }, 1500);
      });

      deviceButton?.addEventListener("click", async () => {
        if (typeof navigator.share === "function") {
          try {
            await navigator.share(payload);
            return;
          } catch (error) {
            if (error && typeof error === "object" && "name" in error && error.name === "AbortError") {
              return;
            }
          }
        }

        const copied = await copyShareText(payload.url);
        if (feedback) {
          feedback.textContent = copied ? "링크 복사됨" : "공유를 사용할 수 없습니다.";
        }
      });
    }
  </script>
</BaseLayout>
