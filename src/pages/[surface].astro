---
import LocaleRedirect from "../components/LocaleRedirect.astro";
import { publicPageIds } from "../content/public-pages";

export function getStaticPaths() {
  return publicPageIds.map((surface) => ({
    params: {
      surface
    },
    props: {
      targetPath: `/${surface}` as `/${string}`
    }
  }));
}

interface Props {
  targetPath: `/${string}`;
}

const { targetPath } = Astro.props as Props;
---

<LocaleRedirect targetPath={targetPath} />
