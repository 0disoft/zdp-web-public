---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicPages, type PublicPage } from "../content/public-pages";

export function getStaticPaths() {
  return publicPages.map((page) => ({
    params: {
      surface: page.id
    },
    props: {
      page
    }
  }));
}

interface Props {
  page: PublicPage;
}

const { page } = Astro.props;
const title = `${page.label} - 8ailors`;
const description = page.summary;
---

<BaseLayout title={title} description={description}>
  <section class="page-hero" aria-labelledby="page-title">
    <a class="back-link" href="/">8ailors 홈</a>
    <p class="eyebrow">{page.label}</p>
    <h1 id="page-title">{page.heading}</h1>
    <p>{page.summary}</p>
  </section>

  {page.items.length > 0 && (
    <section class="detail-section" aria-label={`${page.label} 항목`}>
      <div class="surface-grid">
        {page.items.map((item) => (
          <article class="surface-item">
            <span class="status">{item.status}</span>
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
