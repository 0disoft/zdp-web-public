---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicPages } from "../../content/public-pages";
import GlossaryText from "../../components/GlossaryText.astro";
import { localizedHomeText } from "../../lib/localized-astro";
import { localizePath, siteLocales, type SupportedLocale } from "../../lib/site-locales";

export function getStaticPaths() {
  return siteLocales.map((locale) => ({
    params: {
      locale
    },
    props: {
      locale
    }
  }));
}

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props as Props;
const title = "8ailors";
const description =
  locale === "ko"
    ? "8ailors - 제품, 기록, 정책, 문의 포털"
    : "8ailors - products, notes, policies, and contact";
const homeSections = getPublicPages(locale).filter(
  (section) =>
    section.summary !== undefined ||
    section.items.length > 0 ||
    section.details.length > 0 ||
    section.checks.length > 0
);
const ui = {
  actionsLabel: locale === "ko" ? "주요 이동" : "Primary links",
  viewSuffix: locale === "ko" ? "보기" : "View",
  evidenceLabel: locale === "ko" ? "검증 기준" : "Evidence",
  emptyTitle: locale === "ko" ? "공개 전 기준을 정리하고 있습니다." : "Public standards are being reviewed."
};
const devLocalizationPatcherScript = import.meta.env.DEV
  ? '<script type="module" src="/src/scripts/localization-dev-patcher.ts"></script>'
  : "";
---

<BaseLayout title={title} description={description} currentPath={localizePath("/", locale)} locale={locale}>
  <section class="hero zdp-section zdp-section--spacing-xl" aria-labelledby="home-title">
    <div class="hero-copy-block zdp-container zdp-container--lg zdp-container--padding-md">
      <h1 id="home-title" set:html={localizedHomeText("hero.title", undefined, import.meta.env.DEV, locale)} />
      <div class="actions zdp-inline zdp-inline--gap-sm zdp-inline--align-center" aria-label={ui.actionsLabel}>
        <a
          class="zdp-button zdp-button--md zdp-button--primary"
          href="#products"
          set:html={localizedHomeText("hero.cta.products", undefined, import.meta.env.DEV, locale)}
        />
        <a
          class="zdp-button zdp-button--md zdp-button--secondary"
          href="#trust"
          set:html={localizedHomeText("hero.cta.trust", undefined, import.meta.env.DEV, locale)}
        />
      </div>
    </div>
  </section>

  {homeSections.map((section) => (
    <section
      id={section.id}
      class="section zdp-section zdp-section--spacing-lg zdp-divider zdp-divider--horizontal zdp-divider--subtle"
      aria-labelledby={`${section.id}-title`}
    >
      <div class="section-inner zdp-container zdp-container--lg zdp-container--padding-md">
        <div class="section-intro">
          <p class="section-label">{section.label}</p>
          <h2 id={`${section.id}-title`} class="section-heading">
            {section.heading}
          </h2>
          {section.summary && <p><GlossaryText text={section.summary} locale={locale} /></p>}
          <div class="zdp-toolbar zdp-toolbar--gap-md zdp-toolbar--align-center">
            <div class="zdp-toolbar__main">
              <a class="zdp-link" href={section.path}>
                {locale === "ko" ? `${section.label} ${ui.viewSuffix}` : `${ui.viewSuffix} ${section.label}`}
              </a>
            </div>
            {section.checks.length > 0 && (
              <div class="zdp-toolbar__actions">
                <span class="zdp-badge zdp-badge--primary zdp-badge--sm">{ui.evidenceLabel}</span>
              </div>
            )}
          </div>
        </div>
        {section.items.length > 0 && (
          <div class="surface-grid zdp-grid zdp-grid--columns-three zdp-grid--gap-md">
            {section.items.map((item) => (
              <article class="surface-item zdp-surface zdp-surface--panel zdp-surface--padding-lg">
                <h3>{item.title}</h3>
                <p><GlossaryText text={item.body} locale={locale} /></p>
              </article>
            ))}
          </div>
        )}
        {section.items.length === 0 && section.summary && (
          <section class="zdp-empty-state zdp-empty-state--raised" aria-labelledby={`${section.id}-empty-title`}>
            <div class="zdp-empty-state__body">
              <h3 id={`${section.id}-empty-title`}>{ui.emptyTitle}</h3>
              <p><GlossaryText text={section.summary} locale={locale} /></p>
            </div>
            <div class="zdp-empty-state__actions">
              <a class="zdp-button zdp-button--md zdp-button--secondary" href={section.path}>
                {locale === "ko" ? `${section.label} ${ui.viewSuffix}` : `${ui.viewSuffix} ${section.label}`}
              </a>
            </div>
          </section>
        )}
      </div>
    </section>
  ))}
  <Fragment set:html={devLocalizationPatcherScript} />
</BaseLayout>
