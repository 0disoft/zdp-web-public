---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicPages } from "../content/public-pages";

const title = "8ailors";
const description = "8ailors — 제품, 기록, 정책, 문의 포털";
---

<BaseLayout title={title} description={description}>
  <section class="hero" aria-labelledby="home-title">
    <div class="hero-copy-block">
      <h1 id="home-title">8ailors</h1>
      <div class="actions" aria-label="주요 이동">
        <a class="button" href="#products">제품</a>
        <a class="button secondary" href="#trust">정책</a>
      </div>
    </div>
  </section>

  {publicPages.map((section) => (
    <section id={section.id} class="section" aria-labelledby={`${section.id}-title`}>
      <div class="section-inner">
        <div class="section-intro">
          <p class="section-label">{section.label}</p>
          <h2 id={`${section.id}-title`} class="section-heading">
            {section.heading}
          </h2>
          <p>{section.summary}</p>
          <a class="text-link" href={section.path}>{section.label} 보기</a>
        </div>
        {section.items.length > 0 && (
          <div class="surface-grid">
            {section.items.map((item) => (
              <article class="surface-item">
                <span class="status">{item.status}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  ))}
</BaseLayout>
