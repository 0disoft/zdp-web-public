---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicPages } from "../content/public-pages";

const title = "8ailors";
const description = "8ailors — 제품, 기록, 정책, 문의 포털";
---

<BaseLayout title={title} description={description} currentPath="/">
  <section class="hero zdp-section zdp-section--spacing-xl" aria-labelledby="home-title">
    <div class="hero-copy-block zdp-container zdp-container--lg zdp-container--padding-md">
      <h1 id="home-title">8ailors</h1>
      <div class="actions zdp-inline zdp-inline--gap-sm zdp-inline--align-center" aria-label="주요 이동">
        <a class="zdp-button zdp-button--md zdp-button--primary" href="#products">제품</a>
        <a class="zdp-button zdp-button--md zdp-button--secondary" href="#trust">정책</a>
      </div>
    </div>
  </section>

  {publicPages.map((section) => (
    <section
      id={section.id}
      class="section zdp-section zdp-section--spacing-lg zdp-divider zdp-divider--horizontal zdp-divider--subtle"
      aria-labelledby={`${section.id}-title`}
    >
      <div class="section-inner zdp-container zdp-container--lg zdp-container--padding-md">
        <div class="section-intro">
          <p class="section-label">{section.label}</p>
          <h2 id={`${section.id}-title`} class="section-heading">
            {section.heading}
          </h2>
          <p>{section.summary}</p>
          <div class="zdp-toolbar zdp-toolbar--gap-md zdp-toolbar--align-center">
            <div class="zdp-toolbar__main">
              <a class="zdp-link" href={section.path}>{section.label} 보기</a>
            </div>
            {section.checks.length > 0 && (
              <div class="zdp-toolbar__actions">
                <span class="zdp-badge zdp-badge--primary zdp-badge--sm">검증 기준</span>
              </div>
            )}
          </div>
        </div>
        {section.items.length > 0 && (
          <div class="surface-grid zdp-grid zdp-grid--columns-three zdp-grid--gap-md">
            {section.items.map((item) => (
              <article class="surface-item zdp-surface zdp-surface--panel zdp-surface--padding-lg">
                <span class="zdp-badge zdp-badge--primary zdp-badge--sm">{item.status}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        )}
        {section.items.length === 0 && (
          <section class="zdp-empty-state zdp-empty-state--raised" aria-labelledby={`${section.id}-empty-title`}>
            <div class="zdp-empty-state__body">
              <h3 id={`${section.id}-empty-title`}>공개 전 기준을 정리하고 있습니다.</h3>
              <p>{section.summary}</p>
            </div>
            <div class="zdp-empty-state__actions">
              <a class="zdp-button zdp-button--md zdp-button--secondary" href={section.path}>{section.label} 보기</a>
            </div>
          </section>
        )}
      </div>
    </section>
  ))}
</BaseLayout>
