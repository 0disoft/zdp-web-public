---
import "../styles/global.css";
import { publicPages } from "../content/public-pages";
import GlossarySheet from "../components/GlossarySheet.astro";

interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath } = Astro.props;
const navItems = [
  { href: "/products", label: "제품" },
  { href: "/design", label: "디자인" },
  { href: "/security", label: "보안" },
  { href: "/labs", label: "실험실" },
  { href: "/roadmap", label: "로드맵" },
  { href: "/notes", label: "기록" },
  { href: "/trust", label: "정책" },
  { href: "/contact", label: "문의" }
] as const;

const searchOptions = [
  ...publicPages.flatMap((page) => {
    if (page.id === "design") {
      return [
        { label: "디자인: 개요", href: "/design#design-start" },
        { label: "디자인: 일관성", href: "/design#design-consistency" },
        { label: "디자인: 접근성", href: "/design#design-accessibility" },
        { label: "디자인: 안전", href: "/design#design-safety" },
        { label: "디자인: 현지화", href: "/design#design-locale" },
        { label: "디자인: 기준 토큰", href: "/design#design-tokens" },
        { label: "디자인: 약속", href: "/design#design-checks" }
      ];
    }
    return [{ label: page.label, href: page.path }];
  })
];
---

<!doctype html>
<html lang="ko" data-zdp-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <script is:inline>
      (() => {
        const storageKey = "zdp-web-public-theme";
        const root = document.documentElement;
        let stored = null;

        try {
          stored = window.localStorage.getItem(storageKey);
        } catch {
          stored = null;
        }

        const systemTheme = window.matchMedia?.("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const theme = stored === "light" || stored === "dark" ? stored : systemTheme;

        root.dataset.zdpTheme = theme;
        root.style.colorScheme = theme;
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="zdp-surface-reset">
    <a class="zdp-skip-link" href="#content">본문으로 건너뛰기</a>
    <div class="shell zdp-page zdp-page--canvas">
      <header class="site-header zdp-container zdp-container--lg zdp-container--padding-md" aria-label="사이트 상단">
        <a class="brand zdp-brand-lockup" href="/" aria-label="8ailors 홈">
          <span class="brand-mark zdp-brand-lockup__mark" aria-hidden="true">
            <svg class="brand-mark__ship" viewBox="0 0 48 48" focusable="false">
              <path class="brand-mark__sail brand-mark__sail--aft" d="M23 8v20H12c1.5-7.8 5-14.1 11-20Z" />
              <path class="brand-mark__sail brand-mark__sail--fore" d="M26 6v22h13C36.9 18.2 32.8 11.5 26 6Z" />
              <path class="brand-mark__mast" d="M24 7v24" />
              <path class="brand-mark__hull" d="M8 31h32l-4.6 7H13.8L8 31Z" />
              <path class="brand-mark__wave" d="M12 41c3 1.6 6 1.6 9 0s6-1.6 9 0 5.5 1.5 8 0" />
            </svg>
          </span>
          <span class="brand-name zdp-brand-wordmark zdp-brand-wordmark--compact">8ailors</span>
        </a>

        <div class="header-search zdp-command-field zdp-command-field--md" role="search" aria-label="사이트 검색">
          <label class="zdp-visually-hidden" for="global-search">사이트 검색</label>
          <input
            id="global-search"
            class="zdp-command-field__input"
            type="search"
            placeholder="검색..."
            autocomplete="off"
            aria-keyshortcuts="/"
            aria-autocomplete="list"
            aria-controls="global-search-results"
            aria-expanded="false"
            data-global-search
          />
          <span class="zdp-shortcut-hint" aria-label="검색 단축키 슬래시">
            <kbd class="zdp-kbd zdp-kbd--md">/</kbd>
          </span>
          <div
            id="global-search-results"
            class="header-search-results"
            role="listbox"
            aria-label="검색 결과"
            hidden
            data-global-search-results
          >
            {searchOptions.map((opt, index) => (
              <div
                id={`global-search-option-${index}`}
                class="header-search-option"
                role="option"
                aria-selected="false"
                data-global-search-option
                data-search-label={opt.label}
                data-href={opt.href}
              >
                {opt.label}
              </div>
            ))}
          </div>
        </div>

        <button
          class="site-theme-toggle zdp-theme-toggle zdp-theme-toggle--md"
          type="button"
          aria-label="다크 모드로 전환"
          aria-pressed="false"
          data-site-theme-toggle
          data-zdp-theme-toggle
          data-zdp-theme-state="light"
        >
          <span class="zdp-theme-toggle__icon zdp-theme-toggle__icon--sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="12" cy="12" r="3.6"></circle>
              <path d="M12 3v2.2M12 18.8V21M3 12h2.2M18.8 12H21M5.6 5.6l1.6 1.6M16.8 16.8l1.6 1.6M18.4 5.6l-1.6 1.6M7.2 16.8l-1.6 1.6"></path>
            </svg>
          </span>
          <span class="zdp-theme-toggle__icon zdp-theme-toggle__icon--moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M17.8 15.4A7 7 0 0 1 8.6 6.2 7.4 7.4 0 1 0 17.8 15.4Z"></path>
            </svg>
          </span>
        </button>

        <nav aria-label="주요 링크">
          <ul class="nav-list">
            {navItems.map((item) => (
              <li>
                <a
                  class="zdp-link zdp-link--muted"
                  href={item.href}
                  aria-current={item.href === currentPath ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>
      <main id="content" tabindex="-1">
        <slot />
      </main>
      <footer class="site-footer zdp-container zdp-container--lg zdp-container--padding-md">
        <div class="footer-inner">
          <p class="footer-copyright">© 2026 Rodisoft</p>
          <nav class="footer-links" aria-label="정책 및 문의">
            <ul class="footer-link-list">
              <li><a class="zdp-link zdp-link--muted" href="/privacy">개인정보</a></li>
              <li><a class="zdp-link zdp-link--muted" href="/terms">약관</a></li>
              <li><a class="zdp-link zdp-link--muted" href="/refunds">환불</a></li>
              <li><a class="zdp-link zdp-link--muted" href="/contact">문의</a></li>
              <li><a class="zdp-link zdp-link--muted" href="/about">소개</a></li>
            </ul>
          </nav>
        </div>
      </footer>
    </div>
    <GlossarySheet />

    <script>
      type ThemeMode = "light" | "dark";

      const themeStorageKey = "zdp-web-public-theme";
      const rootElement = document.documentElement;
      const themeToggle = document.querySelector<HTMLButtonElement>("[data-site-theme-toggle]");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");

      function normalizeTheme(value: string | undefined | null): ThemeMode | null {
        return value === "light" || value === "dark" ? value : null;
      }

      function readStoredTheme(): ThemeMode | null {
        try {
          return normalizeTheme(window.localStorage.getItem(themeStorageKey));
        } catch {
          return null;
        }
      }

      function writeStoredTheme(theme: ThemeMode): void {
        try {
          window.localStorage.setItem(themeStorageKey, theme);
        } catch {
          // Storage can be blocked; the visible page theme still updates.
        }
      }

      function preferredTheme(): ThemeMode {
        return prefersDark.matches ? "dark" : "light";
      }

      function syncThemeToggle(theme: ThemeMode): void {
        if (!themeToggle) {
          return;
        }

        const isDark = theme === "dark";
        themeToggle.dataset.zdpThemeState = theme;
        themeToggle.setAttribute("aria-pressed", isDark ? "true" : "false");
        themeToggle.setAttribute("aria-label", isDark ? "라이트 모드로 전환" : "다크 모드로 전환");
      }

      function applyTheme(theme: ThemeMode, persist = false): void {
        rootElement.dataset.zdpTheme = theme;
        rootElement.style.colorScheme = theme;
        syncThemeToggle(theme);

        if (persist) {
          writeStoredTheme(theme);
        }
      }

      applyTheme(normalizeTheme(rootElement.dataset.zdpTheme) ?? readStoredTheme() ?? preferredTheme());

      themeToggle?.addEventListener("click", () => {
        const current = normalizeTheme(rootElement.dataset.zdpTheme) ?? preferredTheme();
        applyTheme(current === "dark" ? "light" : "dark", true);
      });

      prefersDark.addEventListener("change", () => {
        if (!readStoredTheme()) {
          applyTheme(preferredTheme());
        }
      });

      const globalSearch = document.querySelector<HTMLInputElement>("[data-global-search]");
      const globalSearchResults = document.querySelector<HTMLElement>("[data-global-search-results]");
      const globalSearchOptions = Array.from(
        document.querySelectorAll<HTMLElement>("[data-global-search-option]")
      );
      let activeSearchIndex = -1;

      function optionLabel(option: HTMLElement): string {
        return option.dataset.searchLabel || option.textContent?.trim() || "";
      }

      function optionHref(option: HTMLElement): string {
        return option.dataset.href || "";
      }

      const searchOptions = new Map(globalSearchOptions.map((option) => [optionLabel(option), optionHref(option)]));

      function visibleSearchOptions(): HTMLElement[] {
        return globalSearchOptions.filter((option) => !option.hidden);
      }

      function setSearchExpanded(expanded: boolean): void {
        if (!globalSearch || !globalSearchResults) {
          return;
        }

        globalSearch.setAttribute("aria-expanded", expanded ? "true" : "false");
        globalSearchResults.hidden = !expanded;

        if (!expanded) {
          activeSearchIndex = -1;
          globalSearch.removeAttribute("aria-activedescendant");
          for (const option of globalSearchOptions) {
            option.removeAttribute("data-active");
            option.setAttribute("aria-selected", "false");
          }
        }
      }

      function setActiveSearchOption(nextIndex: number): void {
        if (!globalSearch) {
          return;
        }

        const visibleOptions = visibleSearchOptions();
        if (visibleOptions.length === 0) {
          setSearchExpanded(false);
          return;
        }

        activeSearchIndex = (nextIndex + visibleOptions.length) % visibleOptions.length;

        for (const [index, option] of visibleOptions.entries()) {
          const active = index === activeSearchIndex;
          option.dataset.active = active ? "true" : "false";
          option.setAttribute("aria-selected", active ? "true" : "false");
        }

        const activeOption = visibleOptions[activeSearchIndex];
        globalSearch.setAttribute("aria-activedescendant", activeOption.id);
        activeOption.scrollIntoView({ block: "nearest" });
      }

      function updateSearchResults(): void {
        if (!globalSearch) {
          return;
        }

        const query = globalSearch.value.trim().toLocaleLowerCase("ko-KR");
        if (!query) {
          for (const option of globalSearchOptions) {
            option.hidden = true;
            option.removeAttribute("data-active");
            option.setAttribute("aria-selected", "false");
          }
          setSearchExpanded(false);
          return;
        }

        for (const option of globalSearchOptions) {
          const matched = optionLabel(option).toLocaleLowerCase("ko-KR").includes(query);
          option.hidden = !matched;
          option.removeAttribute("data-active");
          option.setAttribute("aria-selected", "false");
        }

        const hasVisibleOptions = visibleSearchOptions().length > 0;
        setSearchExpanded(hasVisibleOptions);

        if (hasVisibleOptions) {
          setActiveSearchOption(0);
        }
      }

      function handleSearchRedirect(value: string): void {
        const target = searchOptions.get(value.trim());
        if (target) {
          window.location.href = target;
          if (globalSearch) {
            globalSearch.value = "";
          }
        }
      }

      function handleOptionRedirect(option: HTMLElement | null | undefined): void {
        const target = option ? optionHref(option) : "";
        if (target) {
          window.location.href = target;
          if (globalSearch) {
            globalSearch.value = "";
          }
        }
      }

      function isComposingKeyEvent(event: KeyboardEvent): boolean {
        return event.isComposing || Reflect.get(event, "keyCode") === 229;
      }

      globalSearch?.addEventListener("change", () => {
        handleSearchRedirect(globalSearch.value);
      });

      globalSearch?.addEventListener("input", () => {
        updateSearchResults();
      });

      globalSearch?.addEventListener("focus", () => {
        updateSearchResults();
      });

      globalSearch?.addEventListener("blur", () => {
        window.setTimeout(() => setSearchExpanded(false), 120);
      });

      globalSearch?.addEventListener("keydown", (event) => {
        if (isComposingKeyEvent(event)) {
          return;
        }

        const visibleOptions = visibleSearchOptions();

        if (event.key === "ArrowDown") {
          event.preventDefault();
          if (visibleOptions.length === 0) {
            updateSearchResults();
          } else {
            setSearchExpanded(true);
            setActiveSearchOption(activeSearchIndex + 1);
          }
          return;
        }

        if (event.key === "ArrowUp") {
          event.preventDefault();
          if (visibleOptions.length > 0) {
            setSearchExpanded(true);
            setActiveSearchOption(activeSearchIndex - 1);
          }
          return;
        }

        if (event.key === "Enter") {
          const activeOption = visibleOptions[activeSearchIndex];
          if (activeOption) {
            event.preventDefault();
            handleOptionRedirect(activeOption);
            return;
          }
          handleSearchRedirect(globalSearch.value);
          return;
        }

        if (event.key === "Escape") {
          setSearchExpanded(false);
        }
      });

      for (const option of globalSearchOptions) {
        option.addEventListener("pointerdown", (event) => {
          event.preventDefault();
          handleOptionRedirect(option);
        });
      }

      document.addEventListener("keydown", (event) => {
        if (isComposingKeyEvent(event)) {
          return;
        }

        const activeElement = document.activeElement;
        const isTyping =
          activeElement instanceof HTMLInputElement ||
          activeElement instanceof HTMLTextAreaElement ||
          activeElement instanceof HTMLSelectElement ||
          activeElement?.getAttribute("contenteditable") === "true" ||
          activeElement?.getAttribute("role") === "textbox" ||
          activeElement?.getAttribute("role") === "searchbox";

        if (event.key === "/" && !event.metaKey && !event.ctrlKey && !event.altKey && !isTyping && globalSearch) {
          event.preventDefault();
          globalSearch.focus();
          globalSearch.select();
        }
      });
    </script>
  </body>
</html>
