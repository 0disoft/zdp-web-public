---
import "../styles/global.css";
import { getPublicPages } from "../content/public-pages";
import GlossarySheet from "../components/GlossarySheet.astro";
import {
  defaultLocale,
  localizePath,
  siteLocaleLabels,
  siteLocales,
  type SupportedLocale
} from "../lib/site-locales";

interface Props {
  title: string;
  description: string;
  currentPath?: string;
  locale?: SupportedLocale;
}

const { title, description, currentPath, locale = defaultLocale } = Astro.props;
const localizedPages = getPublicPages(locale);
const navItems = localizedPages.filter((page) =>
  ["products", "design", "security", "labs", "roadmap", "notes", "trust", "contact"].includes(page.id)
);
const footerItems = localizedPages.filter((page) => ["privacy", "terms", "refunds", "contact", "about"].includes(page.id));
const currentLocalizedPath = currentPath ?? localizePath("/", locale);
const currentLocaleLabel = siteLocaleLabels[locale].short;
const textSample = locale === "ko" ? "가" : "Aa";
// Public links only; auth/session logic is owned outside this static site.
const authEntryRoutes = {
  signIn: "/login",
  signUp: "/signup"
} as const;
const layoutCopy = {
  en: {
    skip: "Skip to content",
    header: "Site header",
    search: "Site search",
    searchPlaceholder: "Search...",
    searchShortcut: "Search shortcut slash",
    searchResults: "Search results",
    preferences: "Display settings",
    language: "Language",
    textScale: "Text size",
    textBase: "Default text size",
    textLarge: "Large text size",
    textLarger: "Larger text size",
    darkMode: "Switch to dark mode",
    lightMode: "Switch to light mode",
    nav: "Primary links",
    footer: "Policies and contact",
    account: "Account",
    signIn: "Sign in",
    signUp: "Sign up"
  },
  ko: {
    skip: "본문으로 건너뛰기",
    header: "사이트 상단",
    search: "사이트 검색",
    searchPlaceholder: "검색...",
    searchShortcut: "검색 단축키 슬래시",
    searchResults: "검색 결과",
    preferences: "화면 설정",
    language: "언어",
    textScale: "글자 크기",
    textBase: "기본 글자 크기",
    textLarge: "큰 글자 크기",
    textLarger: "더 큰 글자 크기",
    darkMode: "다크 모드로 전환",
    lightMode: "라이트 모드로 전환",
    nav: "주요 링크",
    footer: "정책 및 문의",
    account: "계정",
    signIn: "로그인",
    signUp: "회원가입"
  }
}[locale];

const searchOptions = [
  ...localizedPages.flatMap((page) => {
    if (page.id === "design") {
      const designLabels =
        locale === "ko"
          ? [
              ["개요", "design-start"],
              ["일관성", "design-consistency"],
              ["접근성", "design-accessibility"],
              ["안전", "design-safety"],
              ["현지화", "design-locale"],
              ["기준 토큰", "design-showcase"],
              ["약속", "design-checks"]
            ]
          : [
              ["Overview", "design-start"],
              ["Consistency", "design-consistency"],
              ["Accessibility", "design-accessibility"],
              ["Safety", "design-safety"],
              ["Localization", "design-locale"],
              ["Tokens", "design-showcase"],
              ["Promises", "design-checks"]
            ];
      return designLabels.map(([label, hash]) => ({
        label: `${page.label}: ${label}`,
        href: `${page.path}#${hash}`
      }));
    }
    return [{ label: page.label, href: page.path }];
  })
];
---

<!doctype html>
<html lang={locale} data-zdp-locale={locale} data-zdp-theme="light" data-zdp-text-scale="base">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <script is:inline>
      (() => {
        const themeStorageKey = "zdp-web-public-theme";
        const textScaleStorageKey = "zdp-web-public-text-scale";
        const root = document.documentElement;
        let storedTheme = null;
        let storedTextScale = null;

        try {
          storedTheme = window.localStorage.getItem(themeStorageKey);
          storedTextScale = window.localStorage.getItem(textScaleStorageKey);
        } catch {
          storedTheme = null;
          storedTextScale = null;
        }

        const systemTheme = window.matchMedia?.("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : systemTheme;
        const locale = root.dataset.zdpLocale === "en" || root.dataset.zdpLocale === "ko" ? root.dataset.zdpLocale : "en";
        const textScale =
          storedTextScale === "base" || storedTextScale === "large" || storedTextScale === "larger"
            ? storedTextScale
            : "base";

        root.lang = locale;
        root.dataset.zdpLocale = locale;
        root.dataset.zdpTheme = theme;
        root.dataset.zdpTextScale = textScale;
        root.style.colorScheme = theme;
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="zdp-surface-reset">
    <a class="zdp-skip-link" href="#content">{layoutCopy.skip}</a>
    <div class="shell zdp-page zdp-page--canvas">
      <header class="site-header zdp-container zdp-container--lg zdp-container--padding-md" aria-label={layoutCopy.header}>
        <a class="brand zdp-brand-lockup" href={localizePath("/", locale)} aria-label="8ailors">
          <span class="brand-mark zdp-brand-lockup__mark" aria-hidden="true">
            <svg class="brand-mark__ship" viewBox="0 0 48 48" focusable="false">
              <path class="brand-mark__sail brand-mark__sail--aft" d="M23 8v20H12c1.5-7.8 5-14.1 11-20Z" />
              <path class="brand-mark__sail brand-mark__sail--fore" d="M26 6v22h13C36.9 18.2 32.8 11.5 26 6Z" />
              <path class="brand-mark__mast" d="M24 7v24" />
              <path class="brand-mark__hull" d="M8 31h32l-4.6 7H13.8L8 31Z" />
              <path class="brand-mark__wave" d="M12 41c3 1.6 6 1.6 9 0s6-1.6 9 0 5.5 1.5 8 0" />
            </svg>
          </span>
          <span class="brand-name zdp-brand-wordmark zdp-brand-wordmark--compact">8ailors</span>
        </a>

        <div class="header-search zdp-command-field zdp-command-field--md" role="search" aria-label={layoutCopy.search}>
          <label class="zdp-visually-hidden" for="global-search">{layoutCopy.search}</label>
          <input
            id="global-search"
            class="zdp-command-field__input"
            type="search"
            placeholder={layoutCopy.searchPlaceholder}
            autocomplete="off"
            aria-keyshortcuts="/"
            aria-autocomplete="list"
            aria-controls="global-search-results"
            aria-expanded="false"
            data-global-search
          />
          <span class="zdp-shortcut-hint" aria-label={layoutCopy.searchShortcut}>
            <kbd class="zdp-kbd zdp-kbd--md">/</kbd>
          </span>
          <div
            id="global-search-results"
            class="header-search-results"
            role="listbox"
            aria-label={layoutCopy.searchResults}
            hidden
            data-global-search-results
          >
            {searchOptions.map((opt, index) => (
              <div
                id={`global-search-option-${index}`}
                class="header-search-option"
                role="option"
                aria-selected="false"
                data-global-search-option
                data-search-label={opt.label}
                data-href={opt.href}
              >
                {opt.label}
              </div>
            ))}
          </div>
        </div>

        <div class="site-preference-controls" role="group" aria-label={layoutCopy.preferences}>
          <details class="site-preference-menu" data-site-preference-menu>
            <summary class="site-preference-trigger" aria-label={layoutCopy.preferences}>
              <span class="site-preference-trigger__locale" lang={locale}>{currentLocaleLabel}</span>
            </summary>
            <div class="site-preference-panel">
              <section class="site-preference-panel__section" aria-labelledby="site-language-title">
                <h2 id="site-language-title" class="site-preference-panel__title">{layoutCopy.language}</h2>
                <div
                  class="site-locale-switcher zdp-locale-switcher zdp-locale-switcher--md"
                  role="radiogroup"
                  aria-label={layoutCopy.language}
                  data-site-locale-switcher
                  data-zdp-locale-switcher
                  data-zdp-locale-value={locale}
                >
                  {siteLocales.map((optionLocale) => (
                    <button
                      class:list={[
                        "zdp-locale-switcher__item",
                        optionLocale === locale && "zdp-locale-switcher__item--selected"
                      ]}
                      type="button"
                      role="radio"
                      lang={optionLocale}
                      aria-label={siteLocaleLabels[optionLocale].label}
                      aria-checked={optionLocale === locale ? "true" : "false"}
                      tabindex={optionLocale === locale ? "0" : "-1"}
                      data-site-locale-option
                      data-zdp-locale-option
                      data-zdp-locale-option-value={optionLocale}
                    >
                      <span class="zdp-locale-switcher__label" aria-hidden="true">{siteLocaleLabels[optionLocale].short}</span>
                      <span class="site-locale-switcher__name">{siteLocaleLabels[optionLocale].label}</span>
                    </button>
                  ))}
                </div>
              </section>

              <section class="site-preference-panel__section" aria-labelledby="site-text-scale-title">
                <h2 id="site-text-scale-title" class="site-preference-panel__title">{layoutCopy.textScale}</h2>
                <div
                  class="site-text-scale-control zdp-text-scale-control zdp-text-scale-control--md"
                  role="radiogroup"
                  aria-label={layoutCopy.textScale}
                  data-site-text-scale-control
                  data-zdp-text-scale-control
                  data-zdp-text-scale-value="base"
                >
                  <button
                    class="zdp-text-scale-control__item zdp-text-scale-control__item--selected"
                    type="button"
                    role="radio"
                    aria-label={layoutCopy.textBase}
                    aria-checked="true"
                    tabindex="0"
                    data-site-text-scale-option
                    data-zdp-text-scale-option
                    data-zdp-text-scale-option-value="base"
                  >
                    <span class="zdp-text-scale-control__sample" aria-hidden="true">{textSample}</span>
                  </button>
                  <button
                    class="zdp-text-scale-control__item"
                    type="button"
                    role="radio"
                    aria-label={layoutCopy.textLarge}
                    aria-checked="false"
                    tabindex="-1"
                    data-site-text-scale-option
                    data-zdp-text-scale-option
                    data-zdp-text-scale-option-value="large"
                  >
                    <span class="zdp-text-scale-control__sample zdp-text-scale-control__sample--large" aria-hidden="true">{textSample}</span>
                  </button>
                  <button
                    class="zdp-text-scale-control__item"
                    type="button"
                    role="radio"
                    aria-label={layoutCopy.textLarger}
                    aria-checked="false"
                    tabindex="-1"
                    data-site-text-scale-option
                    data-zdp-text-scale-option
                    data-zdp-text-scale-option-value="larger"
                  >
                    <span class="zdp-text-scale-control__sample zdp-text-scale-control__sample--larger" aria-hidden="true">{textSample}</span>
                  </button>
                </div>
              </section>
            </div>
          </details>

          <button
            class="site-theme-toggle zdp-theme-toggle zdp-theme-toggle--md"
            type="button"
            aria-label={layoutCopy.darkMode}
            aria-pressed="false"
            data-site-theme-toggle
            data-zdp-theme-toggle
            data-zdp-theme-state="light"
          >
            <span class="zdp-theme-toggle__icon zdp-theme-toggle__icon--sun" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <circle cx="12" cy="12" r="3.6"></circle>
                <path d="M12 3v2.2M12 18.8V21M3 12h2.2M18.8 12H21M5.6 5.6l1.6 1.6M16.8 16.8l1.6 1.6M18.4 5.6l-1.6 1.6M7.2 16.8l-1.6 1.6"></path>
              </svg>
            </span>
            <span class="zdp-theme-toggle__icon zdp-theme-toggle__icon--moon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M17.8 15.4A7 7 0 0 1 8.6 6.2 7.4 7.4 0 1 0 17.8 15.4Z"></path>
              </svg>
            </span>
          </button>
        </div>

        <nav aria-label={layoutCopy.nav}>
          <ul class="nav-list">
            {navItems.map((item) => (
              <li>
                <a
                  class="zdp-link zdp-link--muted"
                  href={item.path}
                  aria-current={item.path === currentLocalizedPath ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="site-auth-actions" role="group" aria-label={layoutCopy.account}>
          <a class="zdp-link zdp-link--muted site-auth-actions__link" href={authEntryRoutes.signIn}>
            {layoutCopy.signIn}
          </a>
          <a class="zdp-button zdp-button--md zdp-button--secondary site-auth-actions__button" href={authEntryRoutes.signUp}>
            {layoutCopy.signUp}
          </a>
        </div>
      </header>
      <main id="content" tabindex="-1">
        <slot />
      </main>
      <footer class="site-footer zdp-container zdp-container--lg zdp-container--padding-md">
        <div class="footer-inner">
          <p class="footer-copyright">© 2026 Rodisoft</p>
          <nav class="footer-links" aria-label={layoutCopy.footer}>
            <ul class="footer-link-list">
              {footerItems.map((item) => (
                <li><a class="zdp-link zdp-link--muted" href={item.path}>{item.label}</a></li>
              ))}
            </ul>
          </nav>
        </div>
      </footer>
    </div>
    <GlossarySheet locale={locale} />

    <script is:inline define:vars={{ currentLocale: locale, lightModeLabel: layoutCopy.lightMode, darkModeLabel: layoutCopy.darkMode }}>
      const supportedLocales = ["en", "ko"];
      const themeStorageKey = "zdp-web-public-theme";
      const localeStorageKey = "zdp-web-public-locale";
      const textScaleStorageKey = "zdp-web-public-text-scale";
      const rootElement = document.documentElement;
      const preferenceMenu = document.querySelector("[data-site-preference-menu]");
      const themeToggle = document.querySelector("[data-site-theme-toggle]");
      const localeSwitcher = document.querySelector("[data-site-locale-switcher]");
      const localeOptions = Array.from(document.querySelectorAll("[data-site-locale-option]"));
      const textScaleControl = document.querySelector("[data-site-text-scale-control]");
      const textScaleOptions = Array.from(
        document.querySelectorAll("[data-site-text-scale-option]")
      );
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");

      function normalizeTheme(value) {
        return value === "light" || value === "dark" ? value : null;
      }

      function readStoredTheme() {
        try {
          return normalizeTheme(window.localStorage.getItem(themeStorageKey));
        } catch {
          return null;
        }
      }

      function writeStoredTheme(theme) {
        try {
          window.localStorage.setItem(themeStorageKey, theme);
        } catch {
          // Storage can be blocked; the visible page theme still updates.
        }
      }

      function normalizeLocale(value) {
        return supportedLocales.includes(value) ? value : null;
      }

      function writeStoredLocale(locale) {
        try {
          window.localStorage.setItem(localeStorageKey, locale);
        } catch {
          // Storage can be blocked; the visible language state still updates.
        }
      }

      function normalizeTextScale(value) {
        return value === "base" || value === "large" || value === "larger" ? value : null;
      }

      function readStoredTextScale() {
        try {
          return normalizeTextScale(window.localStorage.getItem(textScaleStorageKey));
        } catch {
          return null;
        }
      }

      function writeStoredTextScale(textScale) {
        try {
          window.localStorage.setItem(textScaleStorageKey, textScale);
        } catch {
          // Storage can be blocked; the visible text scale still updates.
        }
      }

      function closePreferenceMenu({ restoreFocus = false } = {}) {
        if (!(preferenceMenu instanceof HTMLDetailsElement) || !preferenceMenu.open) {
          return;
        }

        preferenceMenu.open = false;

        if (restoreFocus) {
          preferenceMenu.querySelector("summary")?.focus();
        }
      }

      function preferredTheme() {
        return prefersDark.matches ? "dark" : "light";
      }

      function syncThemeToggle(theme) {
        if (!themeToggle) {
          return;
        }

        const isDark = theme === "dark";
        themeToggle.dataset.zdpThemeState = theme;
        themeToggle.setAttribute("aria-pressed", isDark ? "true" : "false");
        themeToggle.setAttribute("aria-label", isDark ? lightModeLabel : darkModeLabel);
      }

      function applyTheme(theme, persist = false) {
        rootElement.dataset.zdpTheme = theme;
        rootElement.style.colorScheme = theme;
        syncThemeToggle(theme);

        if (persist) {
          writeStoredTheme(theme);
        }
      }

      function syncLocaleSwitcher(locale) {
        localeSwitcher?.setAttribute("data-zdp-locale-value", locale);

        for (const option of localeOptions) {
          const selected = normalizeLocale(option.dataset.zdpLocaleOptionValue) === locale;
          option.classList.toggle("zdp-locale-switcher__item--selected", selected);
          option.setAttribute("aria-checked", selected ? "true" : "false");
          option.tabIndex = selected ? 0 : -1;
        }
      }

      function applyLocale(locale, persist = false) {
        rootElement.lang = locale;
        rootElement.dataset.zdpLocale = locale;
        syncLocaleSwitcher(locale);

        if (persist) {
          writeStoredLocale(locale);
        }
      }

      function buildLocalizedCurrentPath(locale) {
        const segments = window.location.pathname.split("/").filter(Boolean);
        if (normalizeLocale(segments[0])) {
          segments.shift();
        }

        const suffix = segments.length > 0 ? `/${segments.join("/")}` : "";
        return `/${locale}${suffix}${window.location.search}${window.location.hash}`;
      }

      function navigateLocale(locale) {
        applyLocale(locale, true);
        const target = buildLocalizedCurrentPath(locale);

        if (target !== `${window.location.pathname}${window.location.search}${window.location.hash}`) {
          window.location.href = target;
        }
      }

      function moveLocaleFocus(current, key) {
        const enabledOptions = localeOptions.filter((option) => !option.disabled);
        const currentIndex = Math.max(0, enabledOptions.indexOf(current));
        const nextIndex =
          key === "Home"
            ? 0
            : key === "End"
              ? enabledOptions.length - 1
              : key === "ArrowLeft"
                ? (currentIndex - 1 + enabledOptions.length) % enabledOptions.length
                : (currentIndex + 1) % enabledOptions.length;
        const nextOption = enabledOptions[nextIndex];
        const nextLocale = normalizeLocale(nextOption?.dataset.zdpLocaleOptionValue);

        if (nextOption && nextLocale) {
          nextOption.focus();
          navigateLocale(nextLocale);
        }
      }

      function syncTextScaleControl(textScale) {
        textScaleControl?.setAttribute("data-zdp-text-scale-value", textScale);

        for (const option of textScaleOptions) {
          const selected = normalizeTextScale(option.dataset.zdpTextScaleOptionValue) === textScale;
          option.classList.toggle("zdp-text-scale-control__item--selected", selected);
          option.setAttribute("aria-checked", selected ? "true" : "false");
          option.tabIndex = selected ? 0 : -1;
        }
      }

      function applyTextScale(textScale, persist = false) {
        rootElement.dataset.zdpTextScale = textScale;
        syncTextScaleControl(textScale);

        if (persist) {
          writeStoredTextScale(textScale);
        }
      }

      function moveTextScaleFocus(current, key) {
        const enabledOptions = textScaleOptions.filter((option) => !option.disabled);
        const currentIndex = Math.max(0, enabledOptions.indexOf(current));
        const nextIndex =
          key === "Home"
            ? 0
            : key === "End"
              ? enabledOptions.length - 1
              : key === "ArrowLeft"
                ? (currentIndex - 1 + enabledOptions.length) % enabledOptions.length
                : (currentIndex + 1) % enabledOptions.length;
        const nextOption = enabledOptions[nextIndex];
        const nextTextScale = normalizeTextScale(nextOption?.dataset.zdpTextScaleOptionValue);

        if (nextOption && nextTextScale) {
          nextOption.focus();
          applyTextScale(nextTextScale, true);
        }
      }

      const pageLocale = normalizeLocale(rootElement.dataset.zdpLocale) ?? normalizeLocale(currentLocale) ?? "en";
      const searchLocale = pageLocale === "ko" ? "ko-KR" : "en-US";

      applyTheme(normalizeTheme(rootElement.dataset.zdpTheme) ?? readStoredTheme() ?? preferredTheme());
      applyLocale(pageLocale, true);
      applyTextScale(normalizeTextScale(rootElement.dataset.zdpTextScale) ?? readStoredTextScale() ?? "base");

      themeToggle?.addEventListener("click", () => {
        const current = normalizeTheme(rootElement.dataset.zdpTheme) ?? preferredTheme();
        applyTheme(current === "dark" ? "light" : "dark", true);
      });

      for (const option of textScaleOptions) {
        option.addEventListener("click", () => {
          const textScale = normalizeTextScale(option.dataset.zdpTextScaleOptionValue);

          if (textScale) {
            applyTextScale(textScale, true);
          }
        });

        option.addEventListener("keydown", (event) => {
          if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) {
            return;
          }

          event.preventDefault();
          moveTextScaleFocus(option, event.key);
        });
      }

      for (const option of localeOptions) {
        option.addEventListener("click", () => {
          const locale = normalizeLocale(option.dataset.zdpLocaleOptionValue);

          if (locale) {
            navigateLocale(locale);
          }
        });

        option.addEventListener("keydown", (event) => {
          if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) {
            return;
          }

          event.preventDefault();
          moveLocaleFocus(option, event.key);
        });
      }

      document.addEventListener("pointerdown", (event) => {
        if (!(event.target instanceof Node) || preferenceMenu?.contains(event.target)) {
          return;
        }

        closePreferenceMenu();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closePreferenceMenu({ restoreFocus: true });
        }
      });

      prefersDark.addEventListener("change", () => {
        if (!readStoredTheme()) {
          applyTheme(preferredTheme());
        }
      });

      const globalSearch = document.querySelector("[data-global-search]");
      const globalSearchResults = document.querySelector("[data-global-search-results]");
      const globalSearchOptions = Array.from(
        document.querySelectorAll("[data-global-search-option]")
      );
      let activeSearchIndex = -1;

      function optionLabel(option) {
        return option.dataset.searchLabel || option.textContent?.trim() || "";
      }

      function optionHref(option) {
        return option.dataset.href || "";
      }

      const searchOptions = new Map(globalSearchOptions.map((option) => [optionLabel(option), optionHref(option)]));

      function visibleSearchOptions() {
        return globalSearchOptions.filter((option) => !option.hidden);
      }

      function setSearchExpanded(expanded) {
        if (!globalSearch || !globalSearchResults) {
          return;
        }

        globalSearch.setAttribute("aria-expanded", expanded ? "true" : "false");
        globalSearchResults.hidden = !expanded;

        if (!expanded) {
          activeSearchIndex = -1;
          globalSearch.removeAttribute("aria-activedescendant");
          for (const option of globalSearchOptions) {
            option.removeAttribute("data-active");
            option.setAttribute("aria-selected", "false");
          }
        }
      }

      function setActiveSearchOption(nextIndex) {
        if (!globalSearch) {
          return;
        }

        const visibleOptions = visibleSearchOptions();
        if (visibleOptions.length === 0) {
          setSearchExpanded(false);
          return;
        }

        activeSearchIndex = (nextIndex + visibleOptions.length) % visibleOptions.length;

        for (const [index, option] of visibleOptions.entries()) {
          const active = index === activeSearchIndex;
          option.dataset.active = active ? "true" : "false";
          option.setAttribute("aria-selected", active ? "true" : "false");
        }

        const activeOption = visibleOptions[activeSearchIndex];
        globalSearch.setAttribute("aria-activedescendant", activeOption.id);
        activeOption.scrollIntoView({ block: "nearest" });
      }

      function updateSearchResults() {
        if (!globalSearch) {
          return;
        }

        const query = globalSearch.value.trim().toLocaleLowerCase(searchLocale);
        if (!query) {
          for (const option of globalSearchOptions) {
            option.hidden = true;
            option.removeAttribute("data-active");
            option.setAttribute("aria-selected", "false");
          }
          setSearchExpanded(false);
          return;
        }

        for (const option of globalSearchOptions) {
          const matched = optionLabel(option).toLocaleLowerCase(searchLocale).includes(query);
          option.hidden = !matched;
          option.removeAttribute("data-active");
          option.setAttribute("aria-selected", "false");
        }

        const hasVisibleOptions = visibleSearchOptions().length > 0;
        setSearchExpanded(hasVisibleOptions);

        if (hasVisibleOptions) {
          setActiveSearchOption(0);
        }
      }

      function handleSearchRedirect(value) {
        const target = searchOptions.get(value.trim());
        if (target) {
          window.location.href = target;
          if (globalSearch) {
            globalSearch.value = "";
          }
        }
      }

      function handleOptionRedirect(option) {
        const target = option ? optionHref(option) : "";
        if (target) {
          window.location.href = target;
          if (globalSearch) {
            globalSearch.value = "";
          }
        }
      }

      function isComposingKeyEvent(event) {
        return event.isComposing || Reflect.get(event, "keyCode") === 229;
      }

      globalSearch?.addEventListener("change", () => {
        handleSearchRedirect(globalSearch.value);
      });

      globalSearch?.addEventListener("input", () => {
        updateSearchResults();
      });

      globalSearch?.addEventListener("focus", () => {
        updateSearchResults();
      });

      globalSearch?.addEventListener("blur", () => {
        window.setTimeout(() => setSearchExpanded(false), 120);
      });

      globalSearch?.addEventListener("keydown", (event) => {
        if (isComposingKeyEvent(event)) {
          return;
        }

        const visibleOptions = visibleSearchOptions();

        if (event.key === "ArrowDown") {
          event.preventDefault();
          if (visibleOptions.length === 0) {
            updateSearchResults();
          } else {
            setSearchExpanded(true);
            setActiveSearchOption(activeSearchIndex + 1);
          }
          return;
        }

        if (event.key === "ArrowUp") {
          event.preventDefault();
          if (visibleOptions.length > 0) {
            setSearchExpanded(true);
            setActiveSearchOption(activeSearchIndex - 1);
          }
          return;
        }

        if (event.key === "Enter") {
          const activeOption = visibleOptions[activeSearchIndex];
          if (activeOption) {
            event.preventDefault();
            handleOptionRedirect(activeOption);
            return;
          }
          handleSearchRedirect(globalSearch.value);
          return;
        }

        if (event.key === "Escape") {
          setSearchExpanded(false);
        }
      });

      for (const option of globalSearchOptions) {
        option.addEventListener("pointerdown", (event) => {
          event.preventDefault();
          handleOptionRedirect(option);
        });
      }

      document.addEventListener("keydown", (event) => {
        if (isComposingKeyEvent(event)) {
          return;
        }

        const activeElement = document.activeElement;
        const isTyping =
          activeElement instanceof HTMLInputElement ||
          activeElement instanceof HTMLTextAreaElement ||
          activeElement instanceof HTMLSelectElement ||
          activeElement?.getAttribute("contenteditable") === "true" ||
          activeElement?.getAttribute("role") === "textbox" ||
          activeElement?.getAttribute("role") === "searchbox";

        if (event.key === "/" && !event.metaKey && !event.ctrlKey && !event.altKey && !isTyping && globalSearch) {
          event.preventDefault();
          globalSearch.focus();
          globalSearch.select();
        }
      });
    </script>
  </body>
</html>
