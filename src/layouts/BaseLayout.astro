---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath } = Astro.props;
const navItems = [
  { href: "/products", label: "제품" },
  { href: "/design", label: "디자인" },
  { href: "/security", label: "보안" },
  { href: "/payment-safety", label: "결제 안전" },
  { href: "/labs", label: "실험실" },
  { href: "/roadmap", label: "로드맵" },
  { href: "/notes", label: "기록" },
  { href: "/trust", label: "정책" },
  { href: "/contact", label: "문의" }
] as const;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
  </head>
  <body class="zdp-surface-reset">
    <a class="zdp-skip-link" href="#content">본문으로 건너뛰기</a>
    <div class="shell">
      <header class="site-header" aria-label="사이트 상단">
        <a class="brand" href="/" aria-label="8ailors 홈">
          <span class="brand-mark" aria-hidden="true">8</span>
          <span>8ailors</span>
        </a>
        <nav aria-label="주요 링크">
          <ul class="nav-list">
            {navItems.map((item) => (
              <li>
                <a href={item.href} aria-current={item.href === currentPath ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>
      <main id="content" tabindex="-1">
        <slot />
      </main>
      <footer class="site-footer">
        <p>© 8ailors — 공개 준비 중</p>
      </footer>
    </div>
  </body>
</html>
