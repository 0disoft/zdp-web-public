---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  currentPath?: string;
}

const { title, description, currentPath } = Astro.props;
const navItems = [
  { href: "/products", label: "제품" },
  { href: "/design", label: "디자인" },
  { href: "/security", label: "보안" },
  { href: "/payment-safety", label: "결제 안전" },
  { href: "/labs", label: "실험실" },
  { href: "/roadmap", label: "로드맵" },
  { href: "/notes", label: "기록" },
  { href: "/trust", label: "정책" },
  { href: "/contact", label: "문의" }
] as const;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title}</title>
  </head>
  <body class="zdp-surface-reset">
    <a class="zdp-skip-link" href="#content">본문으로 건너뛰기</a>
    <div class="shell zdp-page zdp-page--canvas">
      <header class="site-header zdp-container zdp-container--lg zdp-container--padding-md" aria-label="사이트 상단">
        <a class="brand" href="/" aria-label="8ailors 홈">
          <span class="brand-mark" aria-hidden="true">
            <svg class="brand-mark__ship" viewBox="0 0 48 48" focusable="false">
              <path class="brand-mark__sail brand-mark__sail--aft" d="M23 8v20H12c1.5-7.8 5-14.1 11-20Z" />
              <path class="brand-mark__sail brand-mark__sail--fore" d="M26 6v22h13C36.9 18.2 32.8 11.5 26 6Z" />
              <path class="brand-mark__mast" d="M24 7v24" />
              <path class="brand-mark__hull" d="M8 31h32l-4.6 7H13.8L8 31Z" />
              <path class="brand-mark__wave" d="M12 41c3 1.6 6 1.6 9 0s6-1.6 9 0 5.5 1.5 8 0" />
            </svg>
          </span>
          <span>8ailors</span>
        </a>
        <nav aria-label="주요 링크">
          <ul class="nav-list">
            {navItems.map((item) => (
              <li>
                <a
                  class="zdp-link zdp-link--muted"
                  href={item.href}
                  aria-current={item.href === currentPath ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>
      <main id="content" tabindex="-1">
        <slot />
      </main>
      <footer class="site-footer zdp-container zdp-container--lg zdp-container--padding-md">
        <p>© 8ailors — 공개 준비 중</p>
      </footer>
    </div>
  </body>
</html>
