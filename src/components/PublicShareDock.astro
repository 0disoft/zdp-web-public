---
import { zdpShareIcons, type ZdpShareIconName } from "zdp-design-system/share";
import type { SupportedLocale } from "../lib/site-locales";

interface Props {
  pageId: string;
  title: string;
  text: string;
  path: string;
  locale: SupportedLocale;
  placement?: "side" | "rail";
}

const { pageId, title, text, path, locale, placement = "side" } = Astro.props;
const copy = {
  en: {
    heading: "Share",
    ariaLabel: `${title} share actions`,
    copy: "Copy link",
    copied: "Copied",
    device: "Share",
    platformSuffix: "Share on"
  },
  ko: {
    heading: "공유",
    ariaLabel: `${title} 공유`,
    copy: "링크 복사",
    copied: "복사됨",
    device: "기기 공유",
    platformSuffix: "공유"
  }
}[locale];
const shareActions = [
  { id: "copy", label: copy.copy, copiedLabel: copy.copied, icon: "copy" },
  { id: "device", label: copy.device, icon: "device" }
] as const satisfies readonly {
  id: string;
  label: string;
  copiedLabel?: string;
  icon: ZdpShareIconName;
}[];
const sharePlatforms = [
  { id: "telegram", label: locale === "ko" ? "텔레그램" : "Telegram", icon: "telegram" },
  { id: "line", label: locale === "ko" ? "라인" : "LINE", icon: "line" },
  { id: "whatsapp", label: locale === "ko" ? "왓츠앱" : "WhatsApp", icon: "whatsapp" },
  { id: "x", label: "X", icon: "x" },
  { id: "reddit", label: locale === "ko" ? "레딧" : "Reddit", icon: "reddit" }
] as const satisfies readonly {
  id: string;
  label: string;
  icon: ZdpShareIconName;
}[];
---

<aside
  class={`zdp-share-dock zdp-share-dock--${placement}`}
  data-share-panel
  data-share-title={title}
  data-share-text={text}
  data-share-locale={locale}
  aria-labelledby={`${pageId}-share-title`}
>
  <h2 id={`${pageId}-share-title`} class="zdp-visually-hidden">{copy.heading}</h2>
  <div class="zdp-share-dock__list" aria-label={copy.ariaLabel}>
    {shareActions.map((action) => {
      const icon = zdpShareIcons[action.icon];

      return (
        <button
          class="zdp-share-action"
          type="button"
          data-share-action={action.id}
          data-share-label={action.label}
          data-share-copied-label={"copiedLabel" in action ? action.copiedLabel : undefined}
          aria-label={action.label}
        >
          <span class="zdp-share-action__mark" aria-hidden="true">
            <svg class={`zdp-share-icon zdp-share-icon--${action.icon}`} viewBox={icon.viewBox} focusable="false">
              {icon.lines?.map((line) => (
                <line
                  x1={line.x1}
                  y1={line.y1}
                  x2={line.x2}
                  y2={line.y2}
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-width={line.strokeWidth ?? "2"}
                />
              ))}
              {icon.paths?.map((path) => (
                <path
                  d={path.d}
                  fill={path.fill === false ? "none" : "currentColor"}
                  stroke={path.stroke ? "currentColor" : undefined}
                  stroke-linecap={path.strokeLinecap}
                  stroke-linejoin={path.strokeLinejoin}
                  stroke-width={path.strokeWidth}
                />
              ))}
              {icon.circles?.map((circle) => (
                <circle
                  cx={circle.cx}
                  cy={circle.cy}
                  r={circle.r}
                  fill={circle.fill === false || circle.stroke ? "none" : "currentColor"}
                  stroke={circle.stroke ? "currentColor" : undefined}
                  stroke-width={circle.strokeWidth}
                />
              ))}
            </svg>
          </span>
          <span class="zdp-share-action__tooltip" aria-hidden="true">{action.label}</span>
        </button>
      );
    })}
    {sharePlatforms.map((platform) => {
      const icon = zdpShareIcons[platform.icon];

      return (
        <a
          class="zdp-share-action"
          href={path}
          target="_blank"
          rel="noopener noreferrer"
          data-share-platform={platform.id}
          aria-label={locale === "ko" ? `${platform.label}으로 공유` : `${copy.platformSuffix} ${platform.label}`}
        >
          <span class="zdp-share-action__mark" aria-hidden="true">
            <svg class={`zdp-share-icon zdp-share-icon--${platform.icon}`} viewBox={icon.viewBox} focusable="false">
              {icon.lines?.map((line) => (
                <line
                  x1={line.x1}
                  y1={line.y1}
                  x2={line.x2}
                  y2={line.y2}
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-width={line.strokeWidth ?? "2"}
                />
              ))}
              {icon.paths?.map((path) => (
                <path
                  d={path.d}
                  fill={path.fill === false ? "none" : "currentColor"}
                  stroke={path.stroke ? "currentColor" : undefined}
                  stroke-linecap={path.strokeLinecap}
                  stroke-linejoin={path.strokeLinejoin}
                  stroke-width={path.strokeWidth}
                />
              ))}
              {icon.circles?.map((circle) => (
                <circle
                  cx={circle.cx}
                  cy={circle.cy}
                  r={circle.r}
                  fill={circle.fill === false || circle.stroke ? "none" : "currentColor"}
                  stroke={circle.stroke ? "currentColor" : undefined}
                  stroke-width={circle.strokeWidth}
                />
              ))}
            </svg>
          </span>
          <span class="zdp-share-action__tooltip" aria-hidden="true">{platform.label}</span>
        </a>
      );
    })}
  </div>
  <span class="zdp-visually-hidden" data-share-feedback aria-live="polite"></span>
</aside>
